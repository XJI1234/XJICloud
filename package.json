{
  "name": "viewer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "deps:install": "npm install",
    "dev": "vite",
    "build:wasm": "node rust/build_wasm.js",
    "build": "vue-tsc -b && vite build",
    "build:supersplat": "cd modules/supersplat && npm install && cross-env BASE_HREF=/supersplat/ npm run build && node ../../scripts/copy-supersplat-dist.mjs",
    "build:all": "npm run build:supersplat && npm run build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"npm run electron:start\"",
    "electron:start": "wait-on tcp:5174 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5174 electron .",
    "electron:build": "npm run build && cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win nsis portable"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "pinia": "^2.3.1",
    "three": "^0.180.0",
    "three-mesh-bvh": "^0.9.10",
    "three-player-controller": "^0.4.5",
    "vue": "^3.5.32",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "magic-string": "^0.30.21",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-glsl": "^1.5.1",
    "vue-tsc": "^3.2.7",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "cn.local.viewer3dgs",
    "productName": "XJI Viewer",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "src-tauri/icons/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
