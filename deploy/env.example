# XJICloud 环境变量示例（复制为 .env 后修改）
# cp deploy/env.example deploy/.env

# ---- 通用 ----
DOMAIN=your-domain.example
PUBLIC_URL=http://your-domain.example

# ---- PostgreSQL（生产 profile）----
POSTGRES_DB=xjicloud
POSTGRES_USER=xjicloud
POSTGRES_PASSWORD=change-me

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- OSS / MinIO（S3 兼容）----
OSS_ENDPOINT=http://minio:9000
OSS_REGION=us-east-1
OSS_BUCKET=xjicloud
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin
# 浏览器直传与 Worker 上传需 bucket CORS，见 Deploy.md

# ---- 后端安全 ----
XJICLOUD_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
XJICLOUD_WORKER_SECRET=replace-with-worker-shared-secret
XJICLOUD_CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174,http://127.0.0.1:5175,https://your-domain.example

# ---- 管理面板默认账号（仅首次启动创建）----
XJICLOUD_ADMIN_USERNAME=admin
XJICLOUD_ADMIN_PASSWORD=admin123

# ---- GPU Worker ----
XJICLOUD_BACKEND_URL=http://backend:8080
WORKER_NAME=xjicloud-gpu-worker-1

# ---- 本地磁盘模型存储（PLY/SPZ，非 OSS 训练流）----
XJICLOUD_STORAGE_ROOT=/data/xjicloud
