# 前端专用 Nginx（前端与后端分机部署）
# 安装：/etc/nginx/conf.d/xjicloud-frontend.conf
#
# 替换：
#   your-domain.example     → 前端域名
#   10.0.1.20               → 后端服务器内网 IP 或域名
#   8080                    → 后端端口

server {
    listen 80;
    server_name your-domain.example;

    root /var/www/xjicloud/dist;
    index index.html;

    client_max_body_size 2048m;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /admin/ {
        root /var/www/xjicloud;
        try_files $uri $uri/ /admin/index.html;
    }

    location /supersplat/ {
        alias /var/www/xjicloud/dist/supersplat/;
        try_files $uri $uri/ /supersplat/index.html;
    }

    # API 反向代理到「后端服务器」（非本机）
    location /api/ {
        proxy_pass http://10.0.1.20:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        add_header X-Accel-Buffering no;
    }
}
