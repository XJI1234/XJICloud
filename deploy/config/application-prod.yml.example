# 生产配置模板（高级用法：手动复制并编辑）
# 推荐首次部署使用交互向导自动生成:
#   sudo ./deploy/deploy-backend.sh configure
#
# 手动方式:
#   cp application-prod.yml.example application-prod.yml
#
# 分布式部署说明：
#   - 后端服务器 B：本配置 + Redis/PostgreSQL（同机或 RDS）
#   - OSS 预生产：MinIO endpoint（如 http://127.0.0.1:9000）
#   - OSS 生产：阿里云 S3 兼容 endpoint https://s3.oss-cn-*.aliyuncs.com，path-style-access: false
#   - cors.allowed-origins 填前端地址；测试可填 * 允许任意来源
#   - 运行时 OSS 可在管理后台「OSS 对象存储」热更新（写入 system_config 表）

spring:
  profiles:
    active: prod
  datasource:
    url: jdbc:postgresql://127.0.0.1:5432/xjicloud
    username: xjicloud
    password: change-me
  data:
    redis:
      host: 127.0.0.1
      port: 6379
      password:
  servlet:
    multipart:
      max-file-size: 2GB
      max-request-size: 2GB
  jpa:
    hibernate:
      ddl-auto: update

server:
  port: 8080

xjicloud:
  jwt:
    secret: replace-with-a-long-random-secret-at-least-32-characters
    expiration-ms: 86400000
  storage:
    root: /data/xjicloud
  cors:
    allowed-origins: "*"
  oss:
    endpoint: http://127.0.0.1:9000
    region: us-east-1
    bucket: xjicloud
    access-key: minioadmin
    secret-key: minioadmin
    path-style-access: true
    presign-expiration-minutes: 120
  redis:
    queue-key: xjicloud:jobs
  worker:
    shared-secret: replace-with-worker-shared-secret
    heartbeat-timeout-sec: 60
    poll-timeout-sec: 25
  admin:
    default-username: admin
    default-password: change-me-after-first-login
    sync-password-on-startup: false
