# 可选：复制为 backend.env，供 systemd 加载（覆盖/补充 JVM 与 Spring 环境变量）
#   cp backend.env.example backend.env
#
# 注意：主要配置请写在 application-prod.yml；此处适合放密钥或运维向变量。

# JAVA_OPTS=-Xms512m -Xmx2g

# 若希望通过环境变量覆盖数据库（需与 application-prod.yml 二选一或保持一致）：
# SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/xjicloud
# SPRING_DATASOURCE_USERNAME=xjicloud
# SPRING_DATASOURCE_PASSWORD=change-me

# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
